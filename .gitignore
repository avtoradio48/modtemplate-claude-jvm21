.gradle
**/build/
!src/**/build/
run/
out/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# IDEA config
.idea

# Local mod dependency jars — copyrighted, must not be committed.
# The libs/ folder itself is kept via libs/PUT_MOD_JARS_HERE.txt
libs/*.jar

